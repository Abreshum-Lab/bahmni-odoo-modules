<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Root Menu -->
    <menuitem
        id="menu_abershum_lab_root"
        name="Abershum Lab"
        sequence="10"/>

    <!-- Settings Menu -->
    <menuitem
        id="menu_abershum_elis_settings_group"
        name="Configuration"
        parent="menu_abershum_lab_root"
        sequence="100"/>

    <menuitem
        id="menu_elis_settings_action"
        name="Settings"
        parent="menu_abershum_elis_settings_group"
        action="abershum_elis_sync_config_settings_action"
        sequence="10"/>
    
    <!-- Master Data Menus -->
    <menuitem
        id="menu_openelis_master_data"
        name="Master Data"
        parent="menu_abershum_lab_root"
        sequence="20"/>

    <menuitem
        id="menu_openelis_department"
        name="Departments"
        parent="menu_openelis_master_data"
        action="openelis_department_action"
        sequence="10"/>

    <menuitem
        id="menu_openelis_sample_type"
        name="Sample Types"
        parent="menu_openelis_master_data"
        action="openelis_sample_type_action"
        sequence="20"/>

    <!-- Operations/Events -->
    <menuitem
        id="menu_openelis_operations"
        name="Operations"
        parent="menu_abershum_lab_root"
        sequence="30"/>

    <menuitem
        id="menu_openelis_failed_events"
        name="Failed Sync Events"
        parent="menu_openelis_operations"
        action="action_openelis_failed_event"
        sequence="10"/>
</odoo>
