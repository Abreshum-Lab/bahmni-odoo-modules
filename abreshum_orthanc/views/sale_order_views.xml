<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_radiology" model="ir.ui.view">
        <field name="name">sale.order.form.radiology</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_print_patient_result" 
                        string="Print Patient Result" 
                        type="object" 
                        class="btn-primary" 
                        attrs="{'invisible': [('state', 'not in', ['sale', 'done'])]}"/>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="options">{'no_quick_create': True, 'no_create_edit': False}</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="provider_id" options="{'no_quick_create': True}"/>
                <field name="radiology_priority"/>
            </xpath>
            <xpath expr="//field[@name='provider_name']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>
